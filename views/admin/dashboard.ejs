<%- include('../partials/header') %>

<section>
  <h1>Portal do Administrador</h1>

  <div class="stats">
    <div class="stat">
      <h3><%= stats.products %></h3>
      <p class="small">Produtos cadastrados</p>
    </div>
    <div class="stat">
      <h3><%= stats.customers %></h3>
      <p class="small">Clientes</p>
    </div>
    <div class="stat">
      <h3><%= stats.orders %></h3>
      <p class="small">Pedidos</p>
    </div>
    <div class="stat">
      <h3>R$ <%= (stats.revenueCents / 100).toFixed(2).replace('.', ',') %></h3>
      <p class="small">Faturamento (sem cancelados)</p>
    </div>
  </div>

  <div class="panel">
    <h2>Ações rápidas</h2>
    <p><a class="btn" href="/admin/products">Gerenciar produtos</a></p>
    <p><a class="btn secondary" href="/admin/orders">Gerenciar pedidos</a></p>
  </div>
</section>

<%- include('../partials/footer') %>

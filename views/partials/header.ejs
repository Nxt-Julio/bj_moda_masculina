<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BJ - Moda Social Masculina</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="announcement">Qualidade premium em gravatas e acessorios - Envio para todo o Brasil</div>

    <header class="site-header">
      <div class="container header-shell">
        <a class="logo" href="/" aria-label="BJ Moda Social Masculina">
          <span class="logo-mark">BJ</span>
          <span class="logo-text">Moda Social Masculina</span>
        </a>

        <nav class="main-nav" aria-label="Menu principal">
          <a href="/#gravatas">Gravatas</a>
          <a href="/#kits">Kits</a>
          <a href="/#crianca">Crianca</a>
          <a href="/#prendedores">Prendedores</a>
          <a href="/#abotoaduras">Abotoaduras</a>
        </nav>

        <div class="header-actions">
          <a class="icon-btn" href="/#produtos" aria-label="Buscar produtos">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M10.5 3a7.5 7.5 0 0 1 5.95 12.07l4.24 4.23a1 1 0 1 1-1.42 1.42l-4.23-4.24A7.5 7.5 0 1 1 10.5 3Zm0 2a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11Z" />
            </svg>
          </a>
          <a class="icon-btn" href="/#produtos" aria-label="Carrinho">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M8 20a2 2 0 1 1 0 4 2 2 0 0 1 0-4Zm9 0a2 2 0 1 1 0 4 2 2 0 0 1 0-4ZM3 2a1 1 0 0 0 0 2h1.12l2.07 9.66A3 3 0 0 0 9.12 16H18a1 1 0 1 0 0-2H9.12a1 1 0 0 1-.98-.79L7.89 12h10.66a3 3 0 0 0 2.93-2.34l1.3-5.52A1 1 0 0 0 21.8 3H6.28L6.03 1.86A1 1 0 0 0 5.05 1H3Z" />
            </svg>
          </a>

          <% if (currentUser) { %>
            <span class="welcome">Ola, <%= currentUser.name %></span>
            <% if (currentUser.role === 'customer') { %>
              <a class="action-link" href="/my-orders">Meus pedidos</a>
            <% } %>
            <% if (currentUser.role === 'admin') { %>
              <a class="action-link" href="/admin">Portal ADM</a>
            <% } %>
            <form class="header-form" action="/logout" method="post">
              <button type="submit" class="action-link">Sair</button>
            </form>
          <% } else { %>
            <a class="action-link" href="/login">Login</a>
            <a class="action-link highlight" href="/register">Cadastro</a>
          <% } %>
        </div>
      </div>
    </header>

    <main class="container">
      <% if (flash) { %>
        <div class="flash <%= flash.type %>"><%= flash.text %></div>
      <% } %>

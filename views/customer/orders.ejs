<%- include('../partials/header') %>

<section>
  <h1>Meus pedidos</h1>

  <% if (orders.length === 0) { %>
    <div class="card"><p>Você ainda não fez pedidos.</p></div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Data</th>
            <th>Status</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach(order => { %>
            <tr>
              <td><%= order.id %></td>
              <td><%= order.created_at %></td>
              <td><%= order.status %></td>
              <td>R$ <%= (order.total_cents / 100).toFixed(2).replace('.', ',') %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include('../partials/footer') %>
